<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Hệ thống Quản trị - Hotel Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🏨 ADMIN PANEL</a>
            <span class="navbar-text">Xin chào, <%= user.username %></span>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <div class="list-group shadow-sm">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action active">Tổng quan</a>
                    <a href="/rooms" class="list-group-item list-group-item-action">Quản lý phòng</a>
                    <a href="/room-types" class="list-group-item list-group-item-action">Loại phòng</a>
                    <a href="/manage/bookings" class="list-group-item list-group-item-action">Đơn đặt hàng</a>
                    <a href="/api/auth/logout" class="list-group-item list-group-item-action text-danger">Đăng xuất</a>
                </div>
            </div>

            <div class="col-md-9">
                <h2 class="fw-bold mb-4">Thống kê hệ thống</h2>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card bg-primary text-white p-3 shadow border-0">
                            <h3><%= stats.totalRooms %></h3>
                            <p>Tổng số phòng</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-success text-white p-3 shadow border-0">
                            <h3><%= stats.totalBookings %></h3>
                            <p>Đơn đặt phòng</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-warning text-dark p-3 shadow border-0">
                            <h3><%= stats.totalStaff %></h3>
                            <p>Nhân viên</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>