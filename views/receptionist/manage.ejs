<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Đặt Phòng - Lễ Tân</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .status-badge { min-width: 100px; text-align: center; }
        .table img { width: 50px; height: 50px; object-fit: cover; border-radius: 5px; }
        
        /* --- PHẦN THÊM MỚI: Style cho sơ đồ phòng nhanh --- */
        .room-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
            gap: 15px; 
            margin-bottom: 40px; 
        }
        .room-item { 
            background: white; 
            border-radius: 12px; 
            padding: 15px; 
            box-shadow: 0 4px 10px rgba(0,0,0,0.05); 
            border-left: 8px solid #ccc; 
            transition: 0.3s;
        }
        /* Màu sắc theo trạng thái */
        .room-item.AVAILABLE { border-left-color: #198754; } /* Xanh lá: Trống */
        .room-item.BOOKED { border-left-color: #dc3545; }    /* Đỏ: Đang ở */
        .room-item.MAINTENANCE { border-left-color: #ffc107; } /* Vàng: Bảo trì */
        
        .room-name { font-weight: bold; font-size: 1.1rem; color: #333; }
        .btn-status-group .btn { font-size: 0.7rem; padding: 3px 6px; font-weight: bold; }
        /* -------------------------------------------------- */
    </style>
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container d-flex justify-content-between align-items-center">
        <a class="navbar-brand" href="/">🏨 HOTEL PRO - RECEPTIONIST</a>
        <div class="d-flex align-items-center">
            <span class="text-white me-3">Chào, <%= user.name %></span>
            <a href="/api/auth/logout" class="btn btn-outline-light btn-sm">🚪 Đăng xuất</a>
        </div>
    </div>
</nav>

<div class="container">
    
    <div class="mb-4">
        <h4 class="text-primary mb-3">🗺️ Quản lý trạng thái phòng nhanh</h4>
        <div class="room-grid">
            <% if (typeof rooms !== 'undefined' && rooms.length > 0) { %>
                <% rooms.forEach(room => { %>
                    <div class="room-item <%= room.status %> shadow-sm">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <span class="room-name">Phòng <%= room.roomCode %></span>
                                <div class="small text-muted"><%= room.roomType?.name %></div>
                            </div>
                            <span class="badge rounded-pill <%= room.status === 'AVAILABLE' ? 'bg-success' : room.status === 'BOOKED' ? 'bg-danger' : 'bg-warning text-dark' %>" style="font-size: 0.65rem;">
                                <%= room.status %>
                            </span>
                        </div>
                        
                        <div class="btn-group btn-status-group w-100 mt-2">
                            <button onclick="updateRoomQuick('<%= room._id %>', 'AVAILABLE')" class="btn btn-outline-success <%= room.status === 'AVAILABLE' ? 'active' : '' %>">TRỐNG</button>
                            <button onclick="updateRoomQuick('<%= room._id %>', 'BOOKED')" class="btn btn-outline-danger <%= room.status === 'BOOKED' ? 'active' : '' %>">Ở</button>
                            <button onclick="updateRoomQuick('<%= room._id %>', 'MAINTENANCE')" class="btn btn-outline-warning <%= room.status === 'MAINTENANCE' ? 'active' : '' %>">SỬA</button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-muted">Chưa có dữ liệu phòng để hiển thị sơ đồ.</p>
            <% } %>
        </div>
    </div>
    <hr class="my-5">

    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <h4 class="mb-0 text-primary">🛎️ Danh Sách Tiếp Nhận Đặt Phòng</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Khách hàng</th>
                            <th>Thông tin phòng</th>
                            <th>Thời gian</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% bookings.forEach(bk => { %>
                            <tr>
                                <td>
                                    <strong><%= bk.user?.name %></strong><br>
                                    <small class="text-muted">📞 <%= bk.user?.phone %></small>
                                </td>
                                <td>
                                    <b>Phòng <%= bk.room?.roomCode %></b><br>
                                    <small><%= bk.room?.roomType?.name %></small>
                                </td>
                                <td>
                                    <small>In: <%= new Date(bk.checkIn).toLocaleDateString('vi-VN') %></small><br>
                                    <small>Out: <%= new Date(bk.checkOut).toLocaleDateString('vi-VN') %></small>
                                </td>
                                <td>
                                    <span class="text-danger fw-bold"><%= bk.totalPrice?.toLocaleString() %>đ</span>
                                </td>
                                <td>
                                    <% if(bk.status === 'CONFIRMED') { %>
                                        <span class="badge bg-primary status-badge">ĐÃ ĐẶT</span>
                                    <% } else if(bk.status === 'CHECKED_IN') { %>
                                        <span class="badge bg-success status-badge">ĐANG Ở</span>
                                    <% } else if(bk.status === 'COMPLETED') { %>
                                        <span class="badge bg-secondary status-badge">HOÀN TẤT</span>
                                    <% } else { %>
                                        <span class="badge bg-danger status-badge">ĐÃ HỦY</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <% if(bk.status === 'CONFIRMED') { %>
                                            <button onclick="changeStatus('<%= bk._id %>', 'CHECKED_IN')" class="btn btn-sm btn-success px-3">Check-in</button>
                                        <% } %>
                                        
                                        <% if(bk.status === 'CHECKED_IN') { %>
                                            <button onclick="openPaymentModal('<%= bk._id %>', '<%= bk.totalPrice %>')" class="btn btn-sm btn-info text-white px-3">Check-out</button>
                                        <% } %>

                                        <% if(bk.status !== 'CANCELLED' && bk.status !== 'COMPLETED') { %>
                                            <button onclick="changeStatus('<%= bk._id %>', 'CANCELLED')" class="btn btn-sm btn-outline-danger">Hủy</button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">💳 Thanh toán & Check-out</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <div class="mb-4">
                    <p class="text-muted mb-1">Tổng chi phí khách phải trả:</p>
                    <h3 class="text-danger fw-bold" id="displayPrice">0đ</h3>
                </div>
                <div id="methodBox">
                    <p class="fw-bold">Chọn hình thức thanh toán:</p>
                    <div class="d-grid gap-3">
                        <button onclick="submitCheckOut('CASH')" class="btn btn-outline-success py-3 fw-bold">💵 Tiền mặt (Bấm OK)</button>
                        <button onclick="showQR()" class="btn btn-outline-primary py-3 fw-bold">📱 Chuyển khoản (Hiện mã QR)</button>
                    </div>
                </div>
                <div id="qrBox" style="display: none;">
                    <h6 class="text-primary fw-bold">MÃ QR NGÂN HÀNG</h6>
                    <img src="/images/123.jpg" class="img-fluid my-3 shadow-sm border p-2" style="max-width: 250px;">
                    <hr>
                    <button onclick="submitCheckOut('TRANSFER')" class="btn btn-info text-white w-100 py-2 fw-bold">OK - Đã nhận tiền</button>
                    <button onclick="hideQR()" class="btn btn-link btn-sm text-secondary mt-2">Quay lại</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
let currentBookingId = null;
const modalObj = new bootstrap.Modal(document.getElementById('paymentModal'));

// ✅ HÀM MỚI: Cập nhật trạng thái phòng qua sơ đồ hình chữ nhật
async function updateRoomQuick(roomId, newStatus) {
    if(!confirm(`Xác nhận đổi trạng thái phòng sang ${newStatus}?`)) return;
    try {
        const res = await fetch(`/api/rooms/${roomId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
        });
        if(res.ok) {
            location.reload();
        } else {
            alert("Lỗi cập nhật phòng!");
        }
    } catch (err) { alert("Lỗi kết nối!"); }
}

// ✅ GIỮ NGUYÊN CÁC LOGIC CŨ CỦA NHÓM
function openPaymentModal(id, price) {
    currentBookingId = id;
    document.getElementById('displayPrice').innerText = Number(price).toLocaleString('vi-VN') + "đ";
    hideQR(); 
    modalObj.show();
}

function showQR() {
    document.getElementById('methodBox').style.display = 'none';
    document.getElementById('qrBox').style.display = 'block';
}

function hideQR() {
    document.getElementById('methodBox').style.display = 'block';
    document.getElementById('qrBox').style.display = 'none';
}

async function submitCheckOut(method) {
    try {
        const res = await fetch(`/api/bookings/update-status/${currentBookingId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'COMPLETED', paymentMethod: method })
        });
        if(res.ok) {
            modalObj.hide();
            alert("✅ Đã hoàn tất trả phòng!");
            location.reload();
        }
    } catch (err) { alert("Lỗi kết nối!"); }
}

async function changeStatus(id, newStatus) {
    if(!confirm(`Xác nhận thao tác?`)) return;
    try {
        const res = await fetch(`/api/bookings/update-status/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
        });
        if(res.ok) location.reload();
    } catch (err) { alert("Lỗi kết nối!"); }
}
</script>

</body>
</html>